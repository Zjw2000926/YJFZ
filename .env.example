# ===== 运行环境 =====
ENV=development
APP_VERSION=1.17.0

# ===== 安全 =====
# 生产环境改为实际域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010,http://localhost:8010,http://127.0.0.1:8010

# ===== 数据库 =====
# 本地开发：sqlite:///./data.db
# Docker 部署：sqlite:///data/data.db（由 docker-compose 自动注入）
DATABASE_URL=sqlite:///./data.db

# ===== 数据目录（P0-02: 静态病例只读 / 运行时数据可写分离）=====
# 本地开发默认使用同一目录 backend/triage_data
# Docker 部署时通过 docker-compose 分别注入
# TRIAGE_STATIC_DATA_DIR=./triage_data
# TRIAGE_RUNTIME_DATA_DIR=./triage_data

# ===== JWT 认证 =====
# 使用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成安全密钥
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ===== DeepSeek API =====
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 是否启用 LLM 驱动虚拟患者对话（true/false）
TRIAGE_USE_LLM=false

# ===== LLM 调用参数 =====
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=90
LLM_CONCURRENT_LIMIT=10
LLM_CONNECTION_POOL_SIZE=20
LLM_CONNECTION_KEEPALIVE=10

# 聊天用短超时 + 少量 token（患者回答 1-3 句话约 80-120 tokens）
LLM_CHAT_TIMEOUT=20
LLM_CHAT_MAX_TOKENS=120
LLM_CHAT_TEMPERATURE=0.65
# 评分用长超时 + 更多 token
LLM_SCORING_TIMEOUT=120
LLM_SCORING_MAX_TOKENS=2048
