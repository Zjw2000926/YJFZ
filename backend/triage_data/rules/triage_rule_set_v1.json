{
  "id": "triage_rule_set_v1", "version": "1.0", "name": "预检分诊四级规则引擎",
  "rules": [
    {"rule_id":"SYMPTOM_CARDIAC_CHEST_PAIN_MIN_II","category":"high_risk_symptom","priority":80,"minimum_level":"Ⅱ级","zone":"red","conditions":{"any_critical_signal":["cardiac_chest_pain"],"any_slot_detected":["pain_radiation","cold_sweat","cardiovascular_risk"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_cardiac_chest_pain","explanation":"胸痛伴冷汗、放射痛或心血管危险因素时，最低应按Ⅱ级处理。"},
    {"rule_id":"SYMPTOM_STROKE_MIN_II","category":"high_risk_symptom","priority":85,"minimum_level":"Ⅱ级","zone":"red","conditions":{"any_critical_signal":["stroke_risk","acute_stroke"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_stroke_risk","explanation":"突发肢体无力或言语含糊提示急性卒中，最低应按Ⅱ级处理，需评估溶栓时间窗。"},
    {"rule_id":"SYMPTOM_RESPIRATORY_FAILURE_MIN_I","category":"critical","priority":100,"minimum_level":"Ⅰ级","zone":"red","conditions":{"any_critical_signal":["respiratory_failure","severe_asthma"],"any_vital":["spo2_below_85"]},"severe_error_if_selected_below":"Ⅱ级","severe_error_code":"missed_respiratory_failure","explanation":"SpO2低于85%或严重呼吸窘迫，最低应按Ⅰ级立即抢救。"},
    {"rule_id":"SYMPTOM_ANAPHYLAXIS_MIN_I","category":"critical","priority":100,"minimum_level":"Ⅰ级","zone":"red","conditions":{"any_critical_signal":["anaphylaxis"]},"severe_error_if_selected_below":"Ⅱ级","severe_error_code":"missed_anaphylaxis","explanation":"喉头水肿伴呼吸困难提示严重过敏反应，最低应按Ⅰ级立即抢救。"},
    {"rule_id":"SYMPTOM_SEPSIS_MIN_II","category":"high_risk_symptom","priority":80,"minimum_level":"Ⅱ级","zone":"red","conditions":{"any_critical_signal":["septic_shock_risk","sepsis"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_sepsis","explanation":"感染伴低血压或意识改变提示脓毒症风险，最低应按Ⅱ级处理。"},
    {"rule_id":"SYMPTOM_ECTOPIC_MIN_II","category":"high_risk_symptom","priority":80,"minimum_level":"Ⅱ级","zone":"red","conditions":{"any_critical_signal":["ectopic_risk"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_ectopic","explanation":"育龄女性下腹痛伴阴道流血不能排除异位妊娠，最低应按Ⅱ级处理。"},
    {"rule_id":"SYMPTOM_PE_RISK_MIN_I","category":"critical","priority":95,"minimum_level":"Ⅰ级","zone":"red","conditions":{"any_critical_signal":["pe_risk"]},"severe_error_if_selected_below":"Ⅱ级","severe_error_code":"missed_pe_risk","explanation":"突发胸痛伴呼吸困难、下肢肿胀和手术史，不能排除肺栓塞，最低应按Ⅰ级处理。"},
    {"rule_id":"SYMPTOM_MAJOR_TRAUMA_MIN_II","category":"high_risk_symptom","priority":75,"minimum_level":"Ⅱ级","zone":"red","conditions":{"any_critical_signal":["major_trauma"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_major_trauma","explanation":"高能量机制多发伤，最低应按Ⅱ级处理，注意脊柱保护。"},
    {"rule_id":"SYMPTOM_SEVERE_DEHYDRATION_MIN_II","category":"high_risk_symptom","priority":70,"minimum_level":"Ⅱ级","zone":"yellow","conditions":{"any_critical_signal":["severe_dehydration"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_dehydration","explanation":"儿童重度脱水(嗜睡、眼窝凹陷、尿少)，最低应按Ⅱ级处理。"},
    {"rule_id":"SYMPTOM_ARRHYTHMIA_MIN_II","category":"high_risk_symptom","priority":75,"minimum_level":"Ⅱ级","zone":"yellow","conditions":{"any_critical_signal":["arrhythmia"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_arrhythmia","explanation":"快速心律失常伴头晕或血流动力学异常，最低应按Ⅱ级处理。"},
    {"rule_id":"SYMPTOM_SUICIDE_RISK_MIN_II","category":"high_risk_symptom","priority":80,"minimum_level":"Ⅱ级","zone":"yellow","conditions":{"any_critical_signal":["suicide_risk"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_suicide_risk","explanation":"自杀意念伴计划，最低应按Ⅱ级处理，精神科急会诊且不得独处。"},
    {"rule_id":"SYMPTOM_SAH_MIN_I","category":"critical","priority":95,"minimum_level":"Ⅰ级","zone":"red","conditions":{"any_critical_signal":["sah"]},"severe_error_if_selected_below":"Ⅱ级","severe_error_code":"missed_sah","explanation":"雷击样头痛伴高血压，不能排除蛛网膜下腔出血，最低应按Ⅰ级处理。"},
    {"rule_id":"SPECIAL_ELDERLY_UPGRADE","category":"special_population","priority":40,"minimum_level":"Ⅱ级","zone":"yellow","conditions":{"special_population:elderly":true,"any_critical_signal_present":true},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"elderly_not_upgraded","explanation":"老年患者合并高危信号时应适当上调分诊等级。"},
    {"rule_id":"SPECIAL_CHILD_UPGRADE","category":"special_population","priority":40,"minimum_level":"Ⅱ级","zone":"yellow","conditions":{"special_population:child":true,"any_critical_signal":["severe_dehydration","pediatric_seizure"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"child_not_upgraded","explanation":"儿童出现高危信号时应适当上调分诊等级。"},
    {"rule_id":"SYMPTOM_MAJOR_HEMORRHAGE_MIN_I","category":"critical","priority":100,"minimum_level":"Ⅰ级","zone":"red","conditions":{"any_critical_signal":["major_hemorrhage","active_bleeding"]},"severe_error_if_selected_below":"Ⅱ级","severe_error_code":"missed_hemorrhage","explanation":"活动性大出血或失血性休克征象，最低应按Ⅰ级立即抢救。"},
    {"rule_id":"SYMPTOM_TOXIC_EXPOSURE_MIN_II","category":"high_risk_symptom","priority":85,"minimum_level":"Ⅱ级","zone":"red","conditions":{"any_critical_signal":["poisoning","toxic_exposure"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_toxic","explanation":"疑似中毒或有毒物暴露史，最低应按Ⅱ级处理，需确认毒物种类和暴露时间。"},
    {"rule_id":"SYMPTOM_OBSTETRIC_EMERGENCY_MIN_I","category":"critical","priority":100,"minimum_level":"Ⅰ级","zone":"red","conditions":{"any_critical_signal":["obstetric_emergency","preeclampsia","eclampsia"]},"severe_error_if_selected_below":"Ⅱ级","severe_error_code":"missed_obstetric","explanation":"孕产妇出现子痫/重度子痫前期或产科急症征象，最低应按Ⅰ级立即处理。"},
    {"rule_id":"SYMPTOM_PEDIATRIC_SEIZURE_MIN_II","category":"high_risk_symptom","priority":85,"minimum_level":"Ⅱ级","zone":"red","conditions":{"any_critical_signal":["pediatric_seizure","febrile_convulsion"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_seizure","explanation":"儿童惊厥持续或首次发作，最低应按Ⅱ级处理。"},
    {"rule_id":"SYMPTOM_VIOLENCE_RISK_MIN_II","category":"high_risk_symptom","priority":80,"minimum_level":"Ⅱ级","zone":"yellow","conditions":{"any_critical_signal":["violence_risk","agitation"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_violence","explanation":"患者存在暴力或激越风险，最低应按Ⅱ级处理，需安排安保和精神科评估。"},
    {"rule_id":"SYMPTOM_INFECTION_EXPOSURE_MIN_II","category":"high_risk_symptom","priority":70,"minimum_level":"Ⅱ级","zone":"yellow","conditions":{"any_critical_signal":["infection_exposure","tb_exposure","covid_exposure"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_infection","explanation":"疑似呼吸道传染病暴露，最低应按Ⅱ级处理，需隔离评估。"},
    {"rule_id":"SYMPTOM_ACUTE_ABDOMEN_MIN_II","category":"high_risk_symptom","priority":80,"minimum_level":"Ⅱ级","zone":"red","conditions":{"any_critical_signal":["acute_abdomen","surgical_abdomen"]},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"missed_acute_abdomen","explanation":"腹膜刺激征或外科急腹症征象，最低应按Ⅱ级处理。"},
    {"rule_id":"SPECIAL_PREGNANT_UPGRADE","category":"special_population","priority":45,"minimum_level":"Ⅱ级","zone":"yellow","conditions":{"special_population:pregnant_possible":true,"any_critical_signal_present":true},"severe_error_if_selected_below":"Ⅲ级","severe_error_code":"pregnant_not_upgraded","explanation":"育龄女性出现高危信号时需排除妊娠，孕期应适当上调分诊等级。"},
    {"rule_id":"SPECIAL_INFECTION_ISOLATION","category":"special_population","priority":40,"minimum_level":"Ⅲ级","zone":"isolation","conditions":{"any_critical_signal":["infection_exposure","tb_exposure","covid_exposure","fever_unknown"]},"explanation":"疑似传染病暴露需安排隔离区域候诊，避免交叉感染。"}
  ]
}
